{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skein",
  "version": "0.1.0",
  "identifier": "dev.skein.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Skein",
        "width": 1480,
        "height": 920,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm"],
    "category": "Productivity",
    "shortDescription": "Local-first notes with built-in semantic search and AI chat.",
    "longDescription": "Skein is a local-first note-taking app: markdown files in a folder you own, with semantic search, RAG-backed chat, daily notes, image attachments, and optional git sync — all running entirely on your machine.",
    "copyright": "Skein contributors",
    "licenseFile": "../LICENSE",
    "homepage": "https://github.com/eavalenzuela/skein",
    "linux": {
      "deb": { "depends": [] }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
